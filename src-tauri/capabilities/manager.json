{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "manager-capability",
  "description": "Permissions for the interview manager panel (list/annotate/export/delete + close/drag)",
  "windows": ["manager"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging"
  ]
}
