{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "answer-capability",
  "description": "Permissions for the pop-out answer overlay (event mirror + close/drag)",
  "windows": ["answer"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-start-dragging"
  ]
}
