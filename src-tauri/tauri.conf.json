{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "gimme-a-chance",
    "version": "0.1.0",
    "identifier": "com.gimmeachance.app",
    "build": {
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "security": {
            "csp": "default-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; connect-src ipc: http://ipc.localhost",
            "freezePrototype": true
        },
        "windows": [
            {
                "label": "main",
                "title": "gimme-a-chance",
                "width": 480,
                "height": 720,
                "resizable": true,
                "transparent": true,
                "decorations": false,
                "alwaysOnTop": true,
                "contentProtected": true
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}